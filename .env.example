# URAI staging environment checklist
# Do not commit real secret values. Keep this file as names-only documentation.

# Firebase / Google Cloud staging separation
# Canonical staging project and Hosting URL for this repo.
URAI_STAGING_PROJECT_ID=urai-staging
URAI_STAGING_URL=https://urai-staging.web.app

# Production is documented only for separation checks. Staging scripts must not deploy to it.
URAI_PRODUCTION_PROJECT_ID=urai-4dc1d
URAI_PRODUCTION_DEPLOY_APPROVED=0

# Local Firebase/GCP project binding for staging-only local tools.
GOOGLE_CLOUD_PROJECT=urai-staging
GCLOUD_PROJECT=urai-staging

# Release evidence
URAI_RELEASE_CANDIDATE_SHA=
URAI_ROLLBACK_TARGET_SHA=
URAI_DEPLOYED_AT=
URAI_STAGING_SMOKE_TESTED=0

# Firebase Admin / local credentials
# Use local-only credentials or CI secrets. Never commit credential files or token values.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_TOKEN=

# OpenAI / AI providers
OPENAI_API_KEY=
OPENAI_MODEL=
AI_PROVIDER=
AI_PROVIDER_API_KEY=

# Render / Python backend
RENDER_API_KEY=
RENDER_SERVICE_ID=
PYTHON_BACKEND_URL=

# Gmail / Google integrations
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GMAIL_SCOPES=

# Stripe / payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Analytics
ANALYTICS_PROVIDER=
ANALYTICS_WRITE_KEY=
GA_MEASUREMENT_ID=

# Storage / CDN
FIREBASE_STORAGE_BUCKET=
CDN_BASE_URL=

# Notifications / SMS / email
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
FCM_SERVER_KEY=

# Production-only values must not be used by staging deploy scripts.

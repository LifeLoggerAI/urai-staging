# This repo currently has no required local secret environment variables.
# Firebase Admin uses application default credentials in deployed Functions.
# Local emulator tests use the Firebase emulator suite.

# Optional: set when running scripts against a specific Firebase project locally.
# GOOGLE_CLOUD_PROJECT=REPLACE_WITH_FIREBASE_STAGING_PROJECT_ID
# GCLOUD_PROJECT=REPLACE_WITH_FIREBASE_STAGING_PROJECT_ID

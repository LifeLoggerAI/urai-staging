{
  "name": "urai-staging",
  "private": true,
  "scripts": {
    "lint": "npm --prefix functions run lint",
    "typecheck": "npm --prefix functions run typecheck",
    "check:types": "npm run typecheck",
    "build": "npm --prefix functions run build",
    "test": "npm --prefix functions run test",
    "test:unit": "npm --prefix functions run test:unit",
    "test:rules": "nix-shell -p adoptopenjdk-bin --run \"npm --prefix functions run test:rules\"",
    "test:e2e": "nix-shell -p adoptopenjdk-bin --run \"npm --prefix functions run test:e2e\"",
    "test:smoke": "npm run smoke:staging",
    "check": "npm --prefix functions run typecheck && npm --prefix functions run build && npm --prefix functions run test:unit",
    "check:all": "npm run check && npm run test:e2e",
    "check:deploy": "node scripts/check-deploy-readiness.mjs",
    "check:firebase": "npm run check:deploy",
    "check:firebase:staging": "npm run check:deploy",
    "check:lockfile": "node scripts/check-lockfile.mjs",
    "check:v1": "npm run check:deploy",
    "validate:completion": "npm run check:deploy",
    "preflight": "npm run check:all",
    "launch:p0": "node scripts/launch-p0.mjs",
    "launch:p0:commands": "node scripts/launch-p0.mjs",
    "smoke:staging": "bash scripts/smoke-staging.sh",
    "test:smoke:staging": "npm run smoke:staging",
    "verify:release": "npm run check:deploy",
    "lock:staging": "bash scripts/urai-staging-lock.sh",
    "emulators": "nix-shell -p adoptopenjdk-bin --run \"./functions/node_modules/.bin/firebase emulators:start --config firebase.json --only functions,firestore,hosting\"",
    "emulators:test": "npm run test:e2e",
    "deploy:staging": "npm run lock:staging",
    "ship:urai:staging": "npm run deploy:staging"
  },
  "engines": {
    "node": "20"
  }
}

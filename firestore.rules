rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function validUserDocument() {
      return request.resource.data.keys().hasOnly([
        'displayName',
        'photoURL',
        'updatedAt'
      ])
      && (!('displayName' in request.resource.data) || request.resource.data.displayName is string)
      && (!('photoURL' in request.resource.data) || request.resource.data.photoURL is string)
      && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp);
    }

    function validEventDocument() {
      return request.resource.data.keys().hasOnly([
        'type',
        'payload',
        'actorUid',
        'createdAt'
      ])
      && request.resource.data.keys().hasAll(['type', 'actorUid', 'createdAt'])
      && request.resource.data.type is string
      && request.resource.data.type.size() > 0
      && request.resource.data.type.size() <= 80
      && request.resource.data.actorUid == request.auth.uid
      && request.resource.data.createdAt is timestamp
      && (!('payload' in request.resource.data) || request.resource.data.payload is map);
    }

    function validJobDocument() {
      return request.resource.data.keys().hasOnly([
        'kind',
        'status',
        'payload',
        'createdAt',
        'createdBy',
        'updatedAt',
        'updatedBy'
      ])
      && request.resource.data.keys().hasAll(['kind', 'status'])
      && request.resource.data.kind is string
      && request.resource.data.kind.size() > 0
      && request.resource.data.kind.size() <= 120
      && request.resource.data.status in ['queued', 'running', 'succeeded', 'failed', 'cancelled']
      && (!('payload' in request.resource.data) || request.resource.data.payload is map)
      && (!('createdAt' in request.resource.data) || request.resource.data.createdAt is timestamp)
      && (!('createdBy' in request.resource.data) || request.resource.data.createdBy is string)
      && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp)
      && (!('updatedBy' in request.resource.data) || request.resource.data.updatedBy is string);
    }

    function validFeatureFlagDocument(flag) {
      return request.resource.data.keys().hasOnly([
        'flag',
        'enabled',
        'description',
        'updatedAt',
        'updatedBy'
      ])
      && request.resource.data.keys().hasAll(['enabled'])
      && request.resource.data.enabled is bool
      && (!('flag' in request.resource.data) || request.resource.data.flag == flag)
      && (!('description' in request.resource.data) || request.resource.data.description is string)
      && (!('updatedAt' in request.resource.data) || request.resource.data.updatedAt is timestamp)
      && (!('updatedBy' in request.resource.data) || request.resource.data.updatedBy is string);
    }

    match /staging_users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && validUserDocument();
      allow delete: if isOwner(userId);
    }

    match /staging_events/{eventId} {
      allow create: if signedIn() && validEventDocument();
      allow read, update, delete: if false;
    }

    match /staging_jobs/{jobId} {
      allow read: if isAdmin();
      allow create, update: if isAdmin() && validJobDocument();
      allow delete: if isAdmin();
    }

    match /staging_featureFlags/{flag} {
      allow read: if signedIn();
      allow create, update: if isAdmin() && validFeatureFlagDocument(flag);
      allow delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
